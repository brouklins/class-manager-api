{
  "name": "class-manager-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist coverage",
    "grant-access": "node scripts/grant-access.mjs",
    "package": "pnpm build && mkdir -p dist/package && cp dist/index.js dist/package/index.js && cd dist/package && zip -rq ../function.zip index.js",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.890.0",
    "@aws-sdk/lib-dynamodb": "^3.890.0",
    "@brouklins/class-manager-shared": "file:../class-manager-shared"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.152",
    "@types/node": "^22.19.19",
    "@vitest/coverage-v8": "^3.2.6",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  }
}
